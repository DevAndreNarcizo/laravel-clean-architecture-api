meta {
  name: Logout
  type: http
  seq: 3
}

post {
  url: {{base_url}}/auth/logout
  body: json
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "refresh_token": "{{refresh_token}}"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

meta {
  name: Me
  type: http
  seq: 2
}

get {
  url: {{base_url}}/auth/me
  body: none
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
  Accept: application/json
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.email: eq test@example.com
  res.body.data.id: isDefined
}

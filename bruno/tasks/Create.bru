meta {
  name: Create
  type: http
  seq: 7
}

post {
  url: {{base_url}}/projects/{{project_id}}/tasks
  body: json
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "title": "Tarefa Bruno Test",
    "description": "Criada pelo teste automatizado"
  }
}

assert {
  res.status: eq 201
  res.body.success: eq true
  res.body.data.title: eq "Tarefa Bruno Test"
  res.body.data.id: isDefined
}

meta {
  name: Update
  type: http
  seq: 9
}

put {
  url: {{base_url}}/tasks/{{task_id}}
  body: json
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "title": "Tarefa Atualizada por Bruno",
    "status": "done"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.title: eq "Tarefa Atualizada por Bruno"
  res.body.data.status: eq "done"
}

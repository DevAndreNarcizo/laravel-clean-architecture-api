meta {
  name: List
  type: http
  seq: 6
}

get {
  url: {{base_url}}/projects/{{project_id}}/tasks
  body: none
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
  Accept: application/json
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data: isDefined
}

meta {
  name: Show
  type: http
  seq: 3
}

get {
  url: {{base_url}}/projects/{{project_id}}
  body: none
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
  Accept: application/json
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.name: isDefined
}
